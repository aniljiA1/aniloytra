    },
    "Enrich – Fetch README": {
      "main": [
        [{ "node": "Merge README Snippet", "type": "main", "index": 0 }]
      ],
      "error": [
        [{ "node": "Error Handler – Notify Discord", "type": "main", "index": 0 }]
      ]
    },
    "Merge README Snippet": {
